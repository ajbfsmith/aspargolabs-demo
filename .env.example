NEXT_PUBLIC_VAPI_PUBLIC_KEY="YOUR_VAPI_PUBLIC_KEY"
NEXT_PUBLIC_VAPI_ASSISTANT_ID="YOUR_VAPI_ASSISTANT_ID"
VAPI_API_KEY="YOUR_VAPI_PRIVATE_API_KEY"
VAPI_TOOL_SERVER_SECRET="shared-secret-sent-by-vapi-tool-header"
VAPI_CUSTOM_LLM_SECRET="shared-secret-sent-by-vapi-custom-llm-header"
VAPI_CUSTOM_LLM_URL="https://YOUR_DEPLOYMENT/api/openai/chat/completions"

# Intake state machine LLM (`lib/intake/extractor` via Vercel AI SDK). Set one backend + its key(s).
# `google` uses `@ai-sdk/google` (Gemini API). Docs: API key defaults to GOOGLE_GENERATIVE_AI_API_KEY.
# `groq` uses `@ai-sdk/groq`; set GROQ_API_KEY (+ optional GROQ_MODEL).
INTAKE_LLM_BACKEND="google"

# Google Generative AI (Gemini) — AI SDK default env name for google(): https://ai-sdk.dev/providers/ai-sdk-providers/google-generative-ai
GOOGLE_GENERATIVE_AI_API_KEY="your-google-generative-ai-api-key"
# Optional override; default Gemini 3.1 Flash‑Lite preview
GEMINI_MODEL="gemini-3.1-flash-lite-preview"

GROQ_API_KEY="your-groq-api-key"
GROQ_MODEL="openai/gpt-oss-120b"

NEXT_PUBLIC_SUPABASE_URL="https://YOUR_PROJECT.supabase.co"
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY="sb_publishable_..."
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"
SUPABASE_PROJECT_ID="your-project-ref"

# Optional: `npm run test:integration` repeats the first scenario INTEGRATION_N times (default 1).
# INTEGRATION_N=3

# Sanity CMS (blog)
SANITY_PROJECT_ID="your-sanity-project-id"
SANITY_DATASET="production"
SANITY_STUDIO_PROJECT_ID="your-sanity-project-id"
SANITY_STUDIO_DATASET="production"
SANITY_API_VERSION="2024-01-01"
SANITY_API_WRITE_TOKEN="your-sanity-write-token"
SANITY_STUDIO_HOST="aspargo-health"
SANITY_AUTH_TOKEN="your-sanity-auth-token"

NEXT_PUBLIC_INTAKE_FORM_URL="https://intake.aspargolabs.com"

# Bask attribution (redirect + webhooks on landing)
# Redirect destination uses NEXT_PUBLIC_INTAKE_FORM_URL (optional override: BASK_INTAKE_BASE_URL)
BASK_WEBHOOK_SECRET="your-bask-webhook-bearer-token"
NEXT_PUBLIC_DEFAULT_CAMPAIGN_ID="your-social-dash-campaign-uuid"

# Production site URL — used for canonical URLs, Open Graph, sitemap, and JSON-LD.
# Set to your live domain before launch (e.g. https://acceleratehealth.co).
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# Optional: Vercel Deploy Hook URL for hourly cron rebuilds (keeps ISR detail pages fresh).
# Create in Vercel → Project → Settings → Git → Deploy Hooks.
# SANITY_DEPLOY_HOOK_URL="https://api.vercel.com/v1/integrations/deploy/..."