NEXT_PUBLIC_SUPABASE_URL="https://YOUR_PROJECT.supabase.co"
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY="sb_publishable_..."
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"
SUPABASE_PROJECT_ID="your-project-ref"

# Optional: `npm run test:integration` repeats the first scenario INTEGRATION_N times (default 1).
# INTEGRATION_N=3

# Sanity CMS (blog) — site pages and scripts read/write this dataset directly.
SANITY_PROJECT_ID="your-sanity-project-id"
SANITY_DATASET="production"
SANITY_STUDIO_PROJECT_ID="your-sanity-project-id"
SANITY_STUDIO_DATASET="production"
SANITY_API_VERSION="2024-01-01"
SANITY_API_WRITE_TOKEN="your-sanity-write-token"
SANITY_STUDIO_HOST="aspargo-health"
SANITY_AUTH_TOKEN="your-sanity-auth-token"

NEXT_PUBLIC_INTAKE_FORM_URL="https://intake.aspargolabs.com"

# Bask attribution (redirect + webhooks on landing)
# Redirect destination uses NEXT_PUBLIC_INTAKE_FORM_URL (optional override: BASK_INTAKE_BASE_URL)
BASK_WEBHOOK_SECRET="your-bask-webhook-bearer-token"
# Browser attribution script → POST /api/attribution/confirm-link-click (Bearer token)
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
ATTRIBUTION_CONFIRM_SECRET="your-attribution-confirm-secret"
# Legacy fallback for site CTAs if needed; persona/landing campaign UUIDs live in lib/attribution/persona-checkout.ts
# Webhook fallback; should match LANDING_CHECKOUT.campaign_id in lib/attribution/persona-checkout.ts
NEXT_PUBLIC_DEFAULT_CAMPAIGN_ID="fed96c9a-97ce-4d43-a556-30d3d45f1212"

# Production site URL — used for canonical URLs, Open Graph, sitemap, and JSON-LD.
# Set to your live domain before launch (e.g. https://acceleratehealth.co).
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# On-demand ISR refresh for /sitemap.xml, /blog, and /blog/[slug].
# Generate: openssl rand -hex 32
# Cron (every 15–30 min): POST https://www.acceleratehealth.co/api/revalidate?secret=YOUR_SECRET
# Optional Sanity webhook → same URL on post create/update.
REVALIDATE_SECRET="your-revalidate-secret"
